j1 = input("Jogador 1: ").strip().lower()
j2 = input("Jogador 2: ").strip().lower()

if j1 == j2:
    print("Empate")
elif (j1 == "pedra" and j2 == "tesoura") or \
     (j1 == "tesoura" and j2 == "papel") or \
     (j1 == "papel" and j2 == "pedra"):
    print("Jogador 1 venceu")
elif (j2 == "pedra" and j1 == "tesoura") or \
     (j2 == "tesoura" and j1 == "papel") or \
     (j2 == "papel" and j1 == "pedra"):
    print("Jogador 2 venceu")
else:
    print("Jogada inválida")